'Salmonellosis (excluding Salmonella Typhi infection and Salmonella Paratyphi infection)',
'Shiga toxin-producing Escherichia coli (STEC)',
'Shigellosis',
'Syphilis, Primary and secondary','Tuberculosis',
'Vibriosis (any species of the family Vibrionaceae, other than toxigenic Vibrio cholerae O1 or O139), Confirmed')
DISEASES_RENAMED = c('West_Nile','Babesiosis','Campylobacteriosis',
'Candida_Auris_Infection','Chlamydia','Coccidioidomycosis',
'Cryptosporidiosis','Cyclosporiasis','Anaplasmosis',
'Ehrlichiosis', 'Giardiasis', 'Gonorrhea',
'Haemophilus_Influenzae',
'Invasive_Pneumococcal','Legionellosis',
'Listeriosis','Malaria','Pertussis',
'Salmonellosis',
'Ecoli_Infection',
'Shigellosis',
'Syphilis','Tuberculosis',
'Vibriosis')
dat = dat[dat$Label %in% DISEASES_TO_KEEP,]
dat = merge(dat, data.frame(Label = DISEASES_TO_KEEP, Label_Pretty = DISEASES_RENAMED),
by = 'Label', all.x = T, all.y =F)
##########################
### Harmonize Diseases ###
##########################
df_sub = dat
DISEASES = unique(df_sub$Label_Pretty)
for(d in 1:length(DISEASES)){
SUB = df_sub[df_sub$Label_Pretty == DISEASES[d],]
data_list = list()
num = 0
LOCATIONS = unique(SUB$Reporting.Area)
for(l in 1:length(LOCATIONS)){
SUBSUB = SUB[SUB$Reporting.Area == LOCATIONS[l],]
temp = create_weekly_dataframe(x=min(SUBSUB$epi_date,na.rm=T), y=max(SUBSUB$epi_date, na.rm=T))
SUBSUB$date_char = as.character(SUBSUB$epi_date)
SUBSUB = merge(SUBSUB, data.frame(date_char = as.character(temp$date), week_index = c(1:length(temp$date))),
by = 'date_char', all.x = T, all.y = T)
SUBSUB = SUBSUB[order(SUBSUB$epi_date),]
ts = rep(0,max(SUBSUB$week_index) - min(SUBSUB$week_index) + 1)
ts[SUBSUB$week_index - min(SUBSUB$week_index)+1] = SUBSUB$Current.week
ts[is.na(ts)] = 0
ts_dates = rep(NA,max(SUBSUB$week_index) - min(SUBSUB$week_index) + 1)
ts_dates[SUBSUB$week_index - min(SUBSUB$week_index)+1] = as.character(SUBSUB$date_char)
ts_dates_actual = rep(NA,max(SUBSUB$week_index) - min(SUBSUB$week_index) + 1)
ts_dates_actual[SUBSUB$week_index - min(SUBSUB$week_index)+1] = as.character(SUBSUB$epi_date)
if(nrow(SUBSUB)>= 10 & !is.na(var(SUBSUB$Current.week, na.rm=T)) & var(SUBSUB$Current.week, na.rm=T) > 0){
num <- num + 1
templist <- list(ts = ts,
ts_dates = ts_dates,
ts_dates_actual = ts_dates_actual,
ts_disease = DISEASES[d],
ts_measurement_type = "incidence",
ts_geography = trimws(LOCATIONS[l]),
ts_first_time = min(SUBSUB$epi_date, na.rm=T),
ts_last_time = max(SUBSUB$epi_date, na.rm=T),
ts_time_cadence = "weekly",
ts_scale = "counts")
data_list[[num]] <- templist
}
}
saveRDS(data_list, paste0(savepath,DISEASES[d],"_nndss.RDS"))
