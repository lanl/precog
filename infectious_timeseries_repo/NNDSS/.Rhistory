}
dat       <- dat[order(dat$epi_date),]
dat = data.frame(dat)
### Recast disease names
#dropped the hepatitis variations, can add back later if we want
DISEASES_TO_KEEP = c('Arboviral diseases, West Nile virus disease','Babesiosis','Campylobacteriosis',
'Candida auris, clinical','Chlamydia trachomatis infection','Coccidioidomycosis, total',
'Cryptosporidiosis','Cyclosporiasis','Ehrlichiosis and Anaplasmosis, Anaplasma phagocytophilum infection',
'Ehrlichiosis and Anaplasmosis, Ehrlichia chaffeensis infection', 'Giardiasis', 'Gonorrhea',
'Haemophilus influenzae, invasive disease, All ages, all serotypes',
'Invasive pneumococcal disease, all ages, Confirmed','Legionellosis',
