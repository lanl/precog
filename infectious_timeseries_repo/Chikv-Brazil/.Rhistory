chikv_brazil = data.frame(chikv_brazil)
unqstate <- sort(unique(chikv_brazil$region))
create_weekly_dataframe <- function(x, y) {
seq_dates <- seq(x, y + 7, by = "week")
subset(data.frame(date = seq_dates), date <= y)
}
chikv_training_data <- list()
cnt <- 0
for(i in 1:length(unqstate)){
print(i)
tempdf <- subset(chikv_brazil, region == unqstate[i])
tempdf <- tempdf[order(tempdf$epi_date),]
### Ensure all weeks are represented
temp = create_weekly_dataframe(x=min(tempdf$epi_date,na.rm=T), y=max(tempdf$epi_date, na.rm=T))
tempdf$date_char = as.character(tempdf$epi_date)
tempdf = merge(tempdf, data.frame(date_char = as.character(temp$date), week_index = c(1:length(temp$date))),
by = 'date_char', all.x = T, all.y = T)
tempdf <- tempdf[order(tempdf$week_index),]
### Require there to be at least 10 weeks represented and nonzero variability in the number of reported cases
if(nrow(tempdf)>= 10  & var(tempdf$CHIKV_cases, na.rm=T) > 0){
cnt <- cnt + 1
ts = rep(0,max(tempdf$week_index) - min(tempdf$week_index) + 1)
ts[tempdf$week_index - min(tempdf$week_index)+1] = tempdf$CHIKV_cases
ts[is.na(ts)]=0
ts_dates = rep(NA,max(tempdf$week_index) - min(tempdf$week_index) + 1)
ts_dates[tempdf$week_index - min(tempdf$week_index)+1] = as.character(tempdf$date_char)
ts_dates_actual = rep(NA,max(tempdf$week_index) - min(tempdf$week_index) + 1)
ts_dates_actual[tempdf$week_index - min(tempdf$week_index)+1] = as.character(tempdf$epi_date)
inds_to_include = min(which(ts>0)):max(which(ts>0))
templist <- list(ts = ts[inds_to_include],
ts_dates = ts_dates[inds_to_include],
ts_dates_actual = ts_dates_actual[inds_to_include],
ts_disease = "chikv",
ts_measurement_type = "incidence",
ts_geography = tempdf$region[1],
ts_first_time = min(tempdf$epi_date[inds_to_include]),
ts_last_time = max(tempdf$epi_date[inds_to_include]),
ts_time_cadence = "weekly",
ts_scale = "counts")
chikv_training_data[[cnt]] <- templist
}
}
ts_dates
ts_dates_actual
sum(ts_dates_actual != ts_dates)
for(i in 1:length(chikv_training_data)){
print(sum(chikv_training_data$ts_dates != chikv_training_data$ts_dates_actual))
}
