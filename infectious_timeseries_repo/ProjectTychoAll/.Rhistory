"Viral hepatitis")
DISEASE_PRETTY = c(
"AcutePolio",
"Amebic_Dysentery"    ,
"Aseptic_Meningitis"  ,
"Babesiosis"           ,
"Bacillary_Dysentery"   ,
"Brucellosis"            ,
"Campylobacteriosis"      ,
"Chlamydia"     ,
"Coccidioidomycosis"        ,
"Cryptosporidiosis"          ,
"Dengue"                      ,
"Diphtheria"                   ,
"Dysentery"                     ,
"Giardiasis"                     ,
"Gonorrhea"                       ,
"Haemophilus_Influenzae" ,
"Hepatitis_NonAB"             ,
"Anaplasmosis"    ,
"Ehrlichiosis"       ,
"Infantile_Paralysis"                                       ,
"Ecoli_Infection_Shiga" ,
"Infective_Encephalitis"  ,
"Influenza1918"                ,
"Ecoli_Infection"   ,
"Invasive_Streptococcus_Pneumoniae"                 ,
"Legionellosis"                                       ,
"Lyme"                                              ,
"Malaria"                                                    ,
"Measles"                                                   ,
"Meningococcal_Infection"                          ,
"Meningococcal_Meningitis"                                  ,
"Mumps"                                                    ,
"Pertussis"                                                 ,
"Pneumonia"                                                 ,
"Postinfectious_Encephalitis" ,
"Primary_Encephalitis"          ,
"Rocky_Mountain_Spotted_Fever"   ,
"Rubella"                         ,
"Salmonellosis"             ,
"Scarlet_Fever"                     ,
"Shigellosis"                        ,
"Smallpox"                            ,
"Streptococcal_Sore_Throat"            ,
"Tuberculosis"                          ,
"Tularemia"                              ,
"Typhoid_Paratyphoid_Fevers"          ,
"Typhoid_Fever"                            ,
"Varicella"                                 ,
"Hepatitis_B"                 ,
"Hepatitis_A"                 ,
"Hepatitis")
for(k in 15:length(DISEASE_TO_PULL)){
dat = try(read.csv(paste0(datapath, paste0(DISEASE_TO_PULL[k],'.csv'))))
dat$loc_id = paste0(dat$CountryCode, '_', dat$Admin1Name, '_', dat$Admin2Name, '_', dat$CityName)
dat$start_date = as.Date(dat$PeriodStartDate, format = '%Y-%m-%d')
dat$end_date = as.Date(dat$PeriodEndDate, format = '%Y-%m-%d')
dat = dat[dat$AgeRange == '0-130',]
dat$diff = as.numeric(difftime(dat$end_date, dat$start_date, units = 'days'))
dat = dat[!is.na(dat$CountValue),]
AGG = aggregate(CountValue~loc_id, FUN = function(x){length(x[!is.na(x) & x > 0])}, data = dat)
AGG = AGG[AGG$CountValue > 50,]
dat = dat[dat$loc_id %in% AGG$loc_id,]
dat$start_index = as.numeric(factor(as.character(dat$start_date), levels = unique(as.character(sort(dat$start_date)))))
dat$end_index = as.numeric(factor(as.character(dat$end_date), levels = unique(as.character(sort(dat$end_date)))))
dat = data.frame(dat)
dat = dat[order(dat$start_index, dat$end_index, dat$loc_id),]
dat = dat[!duplicated(paste0(dat$start_index, '_', dat$end_index, '_', dat$loc_id)),]
dat = dat %>% dplyr::group_by(loc_id,start_index) %>% dplyr::mutate(diff_cases = c(CountValue[1],diff(CountValue)))
dat$diff_cases = pmax(0,dat$diff_cases)
dat = dat[order(dat$start_index, dat$end_index, dat$loc_id),]
dat = dat %>% dplyr::group_by(loc_id,start_index) %>% dplyr::mutate(new_start_date = c(start_date[1], end_date[-length(end_date)]))
dat = dat[order(dat$start_index, dat$end_index, dat$loc_id),]
dat = dat %>% dplyr::group_by(loc_id) %>% dplyr::mutate(cadence = median(as.numeric(difftime(end_date, new_start_date, units = 'days'))))
dat       <- dat[order(dat$new_start_date),]
output_tycho(dat_sub = dat, DISEASE_KEY = DISEASE_PRETTY[k])
print(k)
}
load_data
