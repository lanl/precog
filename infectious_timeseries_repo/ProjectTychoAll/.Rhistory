### Fill out daily or weekly data to include all weeks/days (even if no cases were reported)
### Weekly data were mapped to the nearest regular weekly case report
output_tycho = function(dat_sub, DISEASE_KEY){
data_list = list()
num = 0
LOCATIONS = unique(dat_sub$loc_id)
for(l in 1:length(LOCATIONS)){
SUBSUB = dat_sub[dat_sub$loc_id == LOCATIONS[l],]
SUBSUB = SUBSUB[order(SUBSUB$new_start_date),]
SUBSUB = SUBSUB[-1,]#often large gap in first time
CADENCE = ifelse(SUBSUB$cadence[1] == 0, 'daily', ifelse(SUBSUB$cadence[1] >= 6 & SUBSUB$cadence[1] <= 7, 'weekly', 'monthly'))
if(CADENCE == 'daily'){
### make sure all dates are in dataset
temp = create_daily_dataframe(x=min(SUBSUB$new_start_date,na.rm=T), y=max(SUBSUB$new_start_date, na.rm=T))
SUBSUB$date_char = as.character(SUBSUB$new_start_date)
SUBSUB = merge(SUBSUB, data.frame(date_char = as.character(unique(temp$date)), week_index = c(1:length(unique(SUBSUB$date)))),
by = 'date_char', all.x = T, all.y = T)
}else if(CADENCE == 'weekly'){
### make sure all weeks are in dataset
ind_newyear = lubridate::month(SUBSUB$new_start_date)==1 & lubridate::mday(SUBSUB$new_start_date) == 1
temp = create_weekly_dataframe(x=min(SUBSUB$new_start_date[!ind_newyear]-7,na.rm=T), y=max(SUBSUB$new_start_date[!ind_newyear], na.rm=T))
SUBSUB$date_char_orig = as.character(SUBSUB$new_start_date)
SUBSUB$date_char_orig_end = as.character(SUBSUB$end_date)
SUBSUB$date_char = SUBSUB$date_char_orig
### map data to nearest regular week
### NOTE: Occasionally, incident cases are only reported for a group of several weeks rather than an individual week
### This code is naively allocated all the cases to the first week and zero cases for the other weeks. This problem occurs
### here and there in many of the Project Tycho time series.
SUBSUB$date_char = apply(cbind(SUBSUB$date_char), 1, FUN = function(x, temp){temp[which.min(abs(as.numeric(difftime(as.Date(temp), as.Date(x), units = 'days'))))]}, temp = as.character(temp$date))
SUBSUB = merge(SUBSUB, data.frame(date_char = as.character(unique(temp$date)), week_index = c(1:length(unique(temp$date)))),
by = 'date_char', all.x = T, all.y = T)
SUBSUB = SUBSUB[order(SUBSUB$week_index),]
}else if(CADENCE == 'monthly'){
### we will not include the monthly data
}
if(CADENCE != 'monthly'){
ts = rep(0,max(SUBSUB$week_index) - min(SUBSUB$week_index) + 1)
ts[SUBSUB$week_index - min(SUBSUB$week_index)+1] = SUBSUB$diff_cases
ts[is.na(ts)] = 0
ts_dates = rep(NA,max(SUBSUB$week_index) - min(SUBSUB$week_index) + 1)
ts_dates[SUBSUB$week_index - min(SUBSUB$week_index)+1] = as.character(SUBSUB$date_char)
ts_startdates_orig = rep(NA,max(SUBSUB$week_index) - min(SUBSUB$week_index) + 1)
ts_startdates_orig[SUBSUB$week_index - min(SUBSUB$week_index)+1] = as.character(SUBSUB$date_char_orig)
ts_enddates_orig = rep(NA,max(SUBSUB$week_index) - min(SUBSUB$week_index) + 1)
ts_enddates_orig[SUBSUB$week_index - min(SUBSUB$week_index)+1] = as.character(SUBSUB$date_char_orig_end)
if(nrow(SUBSUB)>= 10 & !is.na(var(SUBSUB$diff_cases, na.rm=T)) & var(SUBSUB$diff_cases, na.rm=T) > 0){
num <- num + 1
templist <- list(ts = ts,
ts_dates = ts_dates,
ts_dates_start_actual = ts_startdates_orig,
ts_dates_end_actual = ts_enddates_orig,
ts_disease = DISEASE_KEY,
ts_measurement_type = "incident_cases",
ts_geography = trimws(LOCATIONS[l]),
ts_first_time = min(SUBSUB$new_start_date, na.rm=T),
ts_last_time = max(SUBSUB$new_start_date, na.rm=T),
ts_time_cadence = CADENCE,
ts_scale = "counts")
data_list[[num]] <- templist
}
}
}
saveRDS(data_list, paste0(savepath,DISEASE_KEY,"_tycho.RDS"))
}
