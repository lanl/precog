}
datapath <- "./raw_data/"
savepath <- "../_Organized_Lists/"
create_weekly_dataframe <- function(x, y) {
seq_dates <- seq(x, y + 7, by = "week")
subset(data.frame(date = seq_dates), date <= y)
}
create_daily_dataframe <- function(x, y) {
seq_dates <- seq(x, y + 1, by = "day")
subset(data.frame(date = date), date <= y)
}
library(dplyr)
FILES = list.files(datapath)
df = data.frame(disease = gsub('.csv','',FILES), num_rows = NA, num_rows_nonzero = NA, num_cases = NA)
for(i in 1:length(FILES)){
dat = try(read.csv(paste0(datapath, FILES[i])))
df$num_rows[i] = nrow(dat)
df$num_rows_nonzero[i] = nrow(dat[dat$CountValue > 0 & !is.na(dat$CountValue),])
df$num_cases[i] = sum(dat$CountValue, na.rm=T)
}
FILES_SUB = FILES[df$num_rows_nonzero > 50]
